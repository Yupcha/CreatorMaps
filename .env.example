# Yupcha Maps — environment variables
# All of these are OPTIONAL. The app runs fully without any keys:
# the basemap uses OpenFreeMap (no key required).
# Copy this file to `.env` and fill in only what you need.

# PostHog product analytics (https://posthog.com).
# Leave blank to disable analytics entirely.
PUBLIC_POSTHOG_KEY=

# Sentry error tracking (https://sentry.io). DSN, not a secret key.
# Leave blank to disable Sentry.
PUBLIC_SENTRY_DSN=
